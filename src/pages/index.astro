---
import PresentationLayout from '../layouts/PresentationLayout.astro';
import Navigation from '../components/Navigation.svelte';
import Slide01Hero from '../components/slides/Slide01Hero.svelte';
import Slide02Recursos from '../components/slides/Slide02Recursos.svelte';
import Slide03PorQueOpenCode from '../components/slides/Slide03PorQueOpenCode.svelte';
import Slide04ComoFunciona from '../components/slides/Slide04ComoFunciona.svelte';
import Slide05Instalacion from '../components/slides/Slide05Instalacion.svelte';
import Slide06DeepSeekKey from '../components/slides/Slide06DeepSeekKey.svelte';
import Slide07AgentsMd from '../components/slides/Slide07AgentsMd.svelte';
import Slide08ContextoSubagentes from '../components/slides/Slide08ContextoSubagentes.svelte';
import Slide09OpenSpec from '../components/slides/Slide09OpenSpec.svelte';
import Slide10FlujoTaller from '../components/slides/Slide10FlujoTaller.svelte';
import Slide11BuenasPracticas from '../components/slides/Slide11BuenasPracticas.svelte';
import Slide12Harness from '../components/slides/Slide12Harness.svelte';
import Slide13ManosALaObra from '../components/slides/Slide13ManosALaObra.svelte';
import Slide14Cierre from '../components/slides/Slide14Cierre.svelte';
---

<PresentationLayout title="Agentes de codificación con OpenCode">
  <Navigation client:load>
    <Slide01Hero />
    <Slide02Recursos client:load />
    <Slide03PorQueOpenCode client:load />
    <Slide04ComoFunciona client:load />
    <Slide05Instalacion client:load />
    <Slide06DeepSeekKey client:load />
    <Slide07AgentsMd client:load />
    <Slide08ContextoSubagentes client:load />
    <Slide09OpenSpec client:load />
    <Slide10FlujoTaller client:load />
    <Slide11BuenasPracticas client:load />
    <Slide12Harness client:load />
    <Slide13ManosALaObra client:load />
    <Slide14Cierre client:load />
  </Navigation>
</PresentationLayout>
